// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  OPS_STAFF
}

enum MovementType {
  ARRIVAL
  DEPARTURE
}

enum OperationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

model User {
  id String @id @default(cuid())

  name         String
  email        String @unique
  passwordHash String

  staffId String   @unique
  role    UserRole

  flightOperations FlightOperation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Airline {
  id String @id @default(cuid())

  name String
  code String @unique

  aircrafts Aircraft[]
  flights   FlightOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Aircraft {
  id String @id @default(cuid())

  registrationNumber String @unique
  type               String
  maxCapacity        Int

  airlineId String
  airline   Airline @relation(fields: [airlineId], references: [id])

  flights FlightOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Airport {
  id String @id @default(cuid())

  name String
  code String @unique

  flights FlightOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bay {
  id String @id @default(cuid())

  name String @unique
  code String @unique

  flights FlightOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlightOperation {
  id String @id @default(cuid())

  flightNumber String

  movementType MovementType

  airlineId String?
  airline   Airline? @relation(fields: [airlineId], references: [id])

  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id])

  airportId String?
  airport   Airport? @relation(fields: [airportId], references: [id])

  bayId String?
  bay   Bay?    @relation(fields: [bayId], references: [id])

  soulsOnBoard Int? // Souls on Board

  scheduledTime String // from FIDS or manual
  actualTime    DateTime? // real recorded time

  delayMinutes Int?
  delayStatus  String?

  date DateTime // Lagos day anchor

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flightNumber, date, movementType])
}

model DailyFlightSchedule {
  id String @id @default(cuid())

  flightNumber String
  airlineCode  String?
  airlineName  String?

  movementType MovementType

  airportCode String?
  airportName String

  scheduledTime String

  status String?

  date DateTime

  createdAt DateTime @default(now())

  @@unique([flightNumber, date, movementType])
  @@index([date])
}
